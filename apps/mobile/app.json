{
  "expo": {
    "name": "Habita",
    "slug": "habita-mobile",
    "scheme": "habita",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "casa.habita.app",
      "associatedDomains": ["applinks:habita.casa"],
      "infoPlist": {
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.615232460202-r8buqnl4jgo1894drai2h4l9qiegutte"
            ]
          }
        ]
      }
    },
    "android": {
      "package": "casa.habita.app",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "habita.casa",
              "pathPrefix": "/join"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "platforms": [
      "ios",
      "android"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "plugins": [
      "expo-router"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b661be21-7f51-4bfc-98ef-a61e7e2d20dd"
      }
    }
  }
}

{
  "expo": {
    "name": "Habita",
    "slug": "habita-mobile",
    "scheme": "habita",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "casa.habita.app",
      "associatedDomains": [
        "applinks:habita.casa",
        "applinks:habita.casa"
      ],
      "infoPlist": {
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.615232460202-r8buqnl4jgo1894drai2h4l9qiegutte"
            ]
          },
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.615232460202-r8buqnl4jgo1894drai2h4l9qiegutte"
            ]
          }
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "casa.habita.app",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "habita.casa",
              "pathPrefix": "/join"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "platforms": [
      "ios",
      "android"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "sounds": []
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a3d7e0b6-2f7c-4a38-b53f-4b9c54f4f14d"
      }
    }
  }
}
